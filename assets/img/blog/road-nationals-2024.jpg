<script type="text/javascript">
var activateNavPage = function () {
  // Highlight the selected page based on the URL and href
  var page = location.href;
  var pages = document.getElementsByClassName('nav-page');

  // first check exact URL
  var i = 0;
  while(i < pages.length) {
    var cur = pages[i].href;
    if (cur === page) {
      pages[i].className += " active";
      return;
    }
    i = i + 1;
  }

  // second check prefix URL
  var i = 1;
  while(i < pages.length) {
    var cur = pages[i].href;
    if (page.indexOf(cur) === 0) {
      pages[i].className += " active";
      return;
    }
    i = i + 1;
  }
}

activateNavPage();
</script>
