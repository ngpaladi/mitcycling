<gpx creator="StravaGPX" version="1.1" xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
 <metadata>
  <name>Fells Green Loop</name>
  <desc>Mountain: This loop is also called the "Mountain bike loop" and is marked by green blazes or bike symbols. It links together mostly fire roads, with some singletrack mixed in. For more singletrack, stay on the orange loop sections instead of turning back onto the green. Overall very rocky trails throughout the Fells, and many technical sections.</desc>
  <author>
   <name>Tim Beaver</name>
   <link href="https://www.strava.com/athletes/23022900"/>
  </author>
  <link href="https://www.strava.com/routes/9542330"/>
 </metadata>
