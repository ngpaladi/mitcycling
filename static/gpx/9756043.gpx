<gpx creator="StravaGPX" version="1.1" xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
 <metadata>
  <name>Trails to and from Concord</name>
  <desc>Mountain: This route is great for CX bikes! Wherever possible, this route favors dirt roads and trails over paved terrain and will take you all the way to out Concord. In some areas, there are more trails to explore (e.g. Beaver Brook and along the Reformatory Branch Trail) - and, in some cases, trails may be overgrown and you will have to put your adventure hats on to find a different way through. Road bikes NOT recommended, but overall not very technical terrain.</desc>
  <author>
   <name>Tim Beaver</name>
   <link href="https://www.strava.com/athletes/23022900"/>
  </author>
  <link href="https://www.strava.com/routes/9756043"/>
 </metadata>
