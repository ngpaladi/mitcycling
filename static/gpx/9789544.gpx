 <metadata>
  <name>Provincetown</name>
  <desc>Century: one-way ride along Cape Cod to Provincetown. Includes lots of quiet roads on the cape and 14 miles of the Cape Cod Rail Trail. You can catch a ferry back to Boston from Provincetown.</desc>
  <author>
   <name>Tim Beaver</name>
   <link href="https://www.strava.com/athletes/23022900"/>
  </author>
  <link href="https://www.strava.com/routes/9789544"/>
 </metadata>
