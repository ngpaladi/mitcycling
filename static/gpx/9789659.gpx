 <metadata>
  <name>Rockport</name>
  <desc>Century: Quiet route with the occasional rolling hills out to the sea by Rockport, north of Boston. Try to avoid purchasing lunch in the touristy area at the turnaround point as there’s very little light food there.</desc>
  <author>
   <name>Tim Beaver</name>
   <link href="https://www.strava.com/athletes/23022900"/>
  </author>
  <link href="https://www.strava.com/routes/9789659"/>
 </metadata>
